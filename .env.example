# Neon Postgres (pooled connection string recommended for serverless)
DATABASE_URL=
# Optional local backup (gitignored): copy URI into secrets/database.local.env — see secrets/README.md

# Optional: copy production DATABASE_URL here to seed / push the live Neon DB from your machine.
#   vercel env pull .env.production.local --environment=production --yes
# Then: npm run db:push:live   (schema)   npm run db:seed:live   (Chennai + articles)
# File name is fixed — do not commit it (.gitignore).

# Public site URL for metadata, sitemap, and robots
NEXT_PUBLIC_SITE_URL=https://mychennaicity.in

# Optional: public contact email (tips, corrections, DPDP — surfaces mailto on /contact)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@mychennaicity.in

# Optional: Google Search Console HTML tag verification — content token only (from GSC → HTML tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: comma-separated profile URLs for Organization JSON-LD (sameAs), e.g. Wikipedia, social
# NEXT_PUBLIC_ORG_SAME_AS=https://twitter.com/yourhandle,https://www.youtube.com/@yourchannel

# Google Analytics 4 (Measurement ID G-...)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: comma-separated client IPs — skip loading GA + AdSense for those visitors (server-only; set on Vercel for prod). See src/lib/analytics-ip-exclusion.ts
# ANALYTICS_EXCLUDE_IPS=203.0.113.10,2001:db8::1

# Google AdSense (after approval) — optional until you enable ads
# ads.txt seller line: use pub-xxxxxxxxxxxxxxxx (same numeric id as in ca-pub-)
# ADSENSE_PUBLISHER_ID=pub-0000000000000000
# Auto ads / script client id:
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=
# Must match the deployed site URL (include https, no trailing slash)
AUTH_URL=https://mychennaicity.in

# OAuth (optional; configure at least one for sign-in)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: Search Console API — npm run gsc:submit-sitemap
# Enable "Google Search Console API" in Google Cloud; create a service account JSON key.
# Add the service account email in GSC → Settings → Users and permissions (Full).
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json
# Or (CI): paste entire JSON as one line in GSC_SERVICE_ACCOUNT_JSON=
# GSC_SITE_URL=https://mychennaicity.in/
# URL-prefix props need trailing slash. Domain property: sc-domain:mychennaicity.in
# GSC_SITEMAP_URL=https://mychennaicity.in/sitemap.xml
