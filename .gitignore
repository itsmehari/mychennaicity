# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Local Neon URI backup (see secrets/README.md)
/secrets/database.local.env

# vercel
.vercel

# Cursor IDE (local skills; do not ship in app repo)
.cursor/

# MCP server dependencies (run npm install in mcp/production-data)
mcp/production-data/node_modules/

# typescript
*.tsbuildinfo
next-env.d.ts
